commit 061ea70cf04a312c01128f603a79c47317703a6e
Author: Cool Bao <bkcsplayer@gmail.com>
Date:   Tue Mar 3 20:19:43 2026 -0700

    Fix ENETUNREACH by routing npm through npmmirror IPv4 registry

diff --git a/frontend/Dockerfile.prod b/frontend/Dockerfile.prod
index 42cae2b..0068070 100644
--- a/frontend/Dockerfile.prod
+++ b/frontend/Dockerfile.prod
@@ -5,13 +5,12 @@ WORKDIR /app
 
 # Copy package files and install dependencies
 COPY package*.json ./
-# Force install all dependencies, ensuring devDependencies are included
-# Disable fund/audit to speed up and reduce network requests
-RUN npm config set registry https://registry.npmjs.org/ && \
+# Force IPv4 routing by using a reliable mirror (npmmirror) instead of default npmjs that triggers IPv6 drops on some VPS routing
+RUN npm config set registry https://registry.npmmirror.com/ && \
     npm install --include=dev --no-fund --no-audit
 
-# Also install vite globally as a fallback
-RUN npm install -g vite
+# Also install vite globally as a fallback using the mirror
+RUN npm install -g vite --registry=https://registry.npmmirror.com/
 
 # Copy source code
 COPY . .

commit 4b7316fbd806efca886ba32f75be581bf047441b
Author: Cool Bao <bkcsplayer@gmail.com>
Date:   Tue Mar 3 20:15:59 2026 -0700

    Fix Vite missing error by globally installing vite as a fallback

diff --git a/frontend/Dockerfile.prod b/frontend/Dockerfile.prod
index bc65587..42cae2b 100644
--- a/frontend/Dockerfile.prod
+++ b/frontend/Dockerfile.prod
@@ -5,14 +5,19 @@ WORKDIR /app
 
 # Copy package files and install dependencies
 COPY package*.json ./
-# Force install all dependencies, ignoring implicit production flags
-RUN npm install --include=dev
+# Force install all dependencies, ensuring devDependencies are included
+# Disable fund/audit to speed up and reduce network requests
+RUN npm config set registry https://registry.npmjs.org/ && \
+    npm install --include=dev --no-fund --no-audit
+
+# Also install vite globally as a fallback
+RUN npm install -g vite
 
 # Copy source code
 COPY . .
 
-# Build the app explicitly using the local binary to bypass npx IPv6 network drops
-RUN ./node_modules/.bin/vite build
+# Build the app using the globally installed or correctly resolved local vite
+RUN vite build
 
 # Nginx serving stage
 FROM nginx:alpine
